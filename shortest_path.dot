digraph WordGraph {
  layout=neato;
  overlap=false;
  splines=true;
  sep="+5";
  node [shape=circle, style=filled, fillcolor="#FFB6C1",
        fontsize=11, fontname="Arial", width=0.6, fixedsize=false];
  edge [fontsize=9, fontname="Arial", color="#2E8B57",
        fontcolor="#333333", arrowsize=0.7];
  "new" [fillcolor="#FFD700"];
  "worlds" [fillcolor="#FFD700"];
  "explore" [fillcolor="#FFD700"];
  "to" [fillcolor="#FFD700"];
  "to" -> "explore" [label="1", color="#FF0000", penwidth=2.5, fontcolor="#FF0000"];
  "to" -> "seek" [label="1", penwidth=1.0];
  "explore" -> "new" [label="1", color="#FF0000", penwidth=2.5, fontcolor="#FF0000"];
  "explore" -> "strange" [label="1", penwidth=1.0];
  "seek" -> "new" [label="1", penwidth=1.0];
  "new" -> "worlds" [label="1", color="#FF0000", penwidth=2.5, fontcolor="#FF0000"];
}
