digraph WordGraph {
  layout=neato;
  overlap=false;
  splines=true;
  sep="+5";
  node [shape=circle, style=filled, fillcolor="#FFB6C1",
        fontsize=11, fontname="Arial", width=0.6, fixedsize=false];
  edge [fontsize=9, fontname="Arial", color="#2E8B57",
        fontcolor="#333333", arrowsize=0.7];
  "b" [fillcolor="#FFD700"];
  "dst" [fillcolor="#FFD700"];
  "src" [fillcolor="#FFD700"];
  "src" -> "a" [label="10", penwidth=8.2];
  "src" -> "b" [label="2", color="#FF0000", penwidth=2.5, fontcolor="#FF0000"];
  "b" -> "a" [label="1", penwidth=1.0];
  "b" -> "dst" [label="100", color="#FF0000", penwidth=2.5, fontcolor="#FF0000"];
}
